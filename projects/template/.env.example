# Project-specific Isaac Sim configuration
#
# Copy this file to .env, fill in your values, and source it before running
# isaac_vmctl.sh:
#
#   cp .env.example .env
#   source .env && /path/to/isaac_vmctl.sh start isaacsim
#
# DO NOT commit .env — it may contain your NGC_API_KEY.

export ISAAC_IMAGE=nvcr.io/nvidia/isaac-sim:5.1.0
export CONTAINER_NAME=isaac-sim
export ISAAC_HOST_ROOT=${HOME}/docker/isaac-sim
export HOST_WORKSPACE_ROOT=
export CONTAINER_WORKSPACE=/workspace/isaac-projects
export CONTAINER_UID=
export CONTAINER_GID=
export WEBRTC_SIGNAL_PORT=49100
export WEBRTC_STREAM_PORT=47998
export ROS_INSTALL_VARIANT=ros-base
export ROS_DOMAIN_ID=0
export NGC_API_KEY=
export ALLOWED_CLIENT_IP=
export TIGERVNC_ENABLE=0
export TIGERVNC_DISPLAY=1
export TIGERVNC_PORT=5901
export TIGERVNC_GEOMETRY=1920x1080
export TIGERVNC_DEPTH=24
export TIGERVNC_LOCALHOST=0
export TIGERVNC_PASSWORD=
export PRIVACY_USERID=
export START_TIMEOUT_SEC=60
export ISAAC_EXTRA_ARGS=
