# Project-specific Isaac Sim configuration
#
# Copy this file to .env, fill in your values, and source it before running
# isaac_vmctl.sh:
#
#   cp .env.example .env
#   source .env && /path/to/isaac_vmctl.sh start isaacsim
#
# DO NOT commit .env — it may contain your NGC_API_KEY.

ISAAC_IMAGE=nvcr.io/nvidia/isaac-sim:5.1.0
CONTAINER_NAME=isaac-sim
ISAAC_HOST_ROOT=${HOME}/docker/isaac-sim
HOST_WORKSPACE_ROOT=
CONTAINER_WORKSPACE=/workspace/isaac-projects
CONTAINER_UID=
CONTAINER_GID=
WEBRTC_SIGNAL_PORT=49100
WEBRTC_STREAM_PORT=47998
ROS_INSTALL_VARIANT=ros-base
ROS_DOMAIN_ID=0
NGC_API_KEY=
ALLOWED_CLIENT_IP=
PRIVACY_USERID=
START_TIMEOUT_SEC=60
ISAAC_EXTRA_ARGS=
