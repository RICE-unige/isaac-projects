# ─── Isaac Sim / Isaac Lab Environment Configuration ──────────────────────────
#
# Copy this file to .env, fill in your values, and source it before running
# the control script:
#
#   cp .env.example .env
#   # edit .env
#   source .env && ./isaac_vmctl.sh start isaacsim
#
# Alternatively, source one of the pre-built version configs first, then
# override individual variables here:
#
#   source configs/isaac-sim-5.1.0.env
#   source .env
#   ./isaac_vmctl.sh start isaacsim
#
# Note: the script does NOT auto-load this file. You must source it explicitly.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Isaac Sim Image ───────────────────────────────────────────────────────────
# Full nvcr.io tag for the Isaac Sim container image.
# See configs/ for pre-built per-version files.
# Find available tags at: https://catalog.ngc.nvidia.com/orgs/nvidia/containers/isaac-sim
ISAAC_IMAGE=nvcr.io/nvidia/isaac-sim:5.1.0

# ─── Container identity ────────────────────────────────────────────────────────
# Name given to the Docker container. If multiple students share one VM,
# each must use a unique container name (e.g. isaac-sim-alice, isaac-sim-bob).
CONTAINER_NAME=isaac-sim

# ─── Workspace mount ───────────────────────────────────────────────────────────
# Host repo/project path mounted into the Isaac Sim container.
# Defaults to this repository when unset.
HOST_WORKSPACE_ROOT=

# Container path where the workspace appears.
CONTAINER_WORKSPACE=/workspace/isaac-projects

# Container user. Leave empty to use your host UID/GID, which lets training
# write checkpoints into projects/<name>/artifacts without ownership issues.
CONTAINER_UID=
CONTAINER_GID=

# ─── Host filesystem ───────────────────────────────────────────────────────────
# Root directory on the host bind-mounted into the container for caches, logs,
# and local config. Defaults to ~/docker/isaac-sim when unset.
# On cloud servers this is not a backup; the server is deleted after allocation.
# On shared machines, set this to a per-user path to avoid cache collisions.
ISAAC_HOST_ROOT=

# ─── WebRTC streaming ports ────────────────────────────────────────────────────
# Signal port (TCP) — the port your browser / Isaac Sim client connects to first.
# On shared VMs, each user must choose a unique port pair.
WEBRTC_SIGNAL_PORT=49100

# Media port (UDP) — carries the actual video/audio stream.
WEBRTC_STREAM_PORT=47998

# ─── ROS 2 ─────────────────────────────────────────────────────────────────────
# ros-base  -> minimal install; recommended for assigned cloud/headless servers
# desktop   -> includes RViz2, rqt, and GUI tools; use on local workstations
ROS_INSTALL_VARIANT=ros-base
ROS_DOMAIN_ID=0

# ─── Firewall ──────────────────────────────────────────────────────────────────
# If ufw is active on the VM, restrict WebRTC access to this IP only.
# Leave empty to allow from any IP (less secure on public cloud VMs).
# This does not configure SimplePod/Vast.ai port rules; set those separately.
ALLOWED_CLIENT_IP=

# ─── Privacy / telemetry ───────────────────────────────────────────────────────
# Associate NVIDIA Omniverse telemetry with a known identity (your email).
# Leave empty to keep the default anonymous behaviour.
PRIVACY_USERID=

# ─── NGC authentication ────────────────────────────────────────────────────────
# Required only if nvcr.io asks for credentials in your environment.
# Generate at: https://ngc.nvidia.com/setup/api-key
# Never commit this value — keep it in your local .env only.
NGC_API_KEY=

# ─── Startup timeout ───────────────────────────────────────────────────────────
# Seconds the script waits for the WebRTC signal port to become active
# after the container launches. Increase for slower machines or Isaac Lab.
START_TIMEOUT_SEC=30

# ─── Extra Isaac Sim arguments ─────────────────────────────────────────────────
# Appended verbatim to the runheadless.sh command inside the container.
# Example — enable the ROS 2 bridge extension:
#   ISAAC_EXTRA_ARGS="--/app/enableExtensions/0=omni.isaac.ros2_bridge"
ISAAC_EXTRA_ARGS=
