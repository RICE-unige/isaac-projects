# Isaac Lab overlay configuration
#
# In this repo, Isaac Lab is bootstrap-managed when this overlay is sourced.
# Bootstrap will:
#   1. clone/update a pinned Isaac Lab checkout under ISAACLAB_PATH
#   2. build a local managed Isaac Lab image on top of ISAAC_IMAGE
#
# Students then run Isaac Lab with:
#   ./isaac_vmctl.sh run isaaclab '...'
#
# Source this file ON TOP of a version config:
#   source configs/isaac-sim-5.1.0.env
#   source configs/isaac-lab.env
#   ./isaac_vmctl.sh bootstrap
#   ./isaac_vmctl.sh run isaaclab '-p scripts/reinforcement_learning/rsl_rl/train.py --task=Isaac-Ant-v0 --headless'
#
# Changing ISAACLAB_REF or ISAACLAB_FRAMEWORKS requires rerunning bootstrap.

# Enable managed Isaac Lab bootstrap steps.
export ISAACLAB_ENABLE=1

# Official upstream Isaac Lab repo.
export ISAACLAB_REPO_URL=https://github.com/isaac-sim/IsaacLab.git

# Pin the Isaac Lab version compatible with this Isaac Sim image.
export ISAACLAB_REF=v2.3.2

# Workspace-relative path to the managed Isaac Lab checkout.
export ISAACLAB_PATH="${ISAACLAB_PATH:-external/IsaacLab}"

# Learning frameworks to install into the managed Isaac Lab image.
# Valid values follow isaaclab.sh --install: all, rl_games, rsl_rl, sb3, skrl,
# robomimic, or none.
export ISAACLAB_FRAMEWORKS=rsl_rl

# Optional override for the managed image tag. Leave empty for the default
# auto-generated local tag.
# export ISAACLAB_IMAGE=rice/isaac-lab:5.1.0-v2.3.2-rsl_rl

# Enable the ROS 2 bridge extension - required for ROS 2 <-> Isaac Lab topics.
export ISAAC_EXTRA_ARGS="--/app/enableExtensions/0=omni.isaac.ros2_bridge"

# Isaac Lab extension loading takes more time than bare Isaac Sim.
export START_TIMEOUT_SEC=90
