# SimplePod TigerVNC desktop overlay
#
# Source this on top of an Isaac Sim version config before bootstrap when the
# SimplePod VM should expose a browser-independent GNOME desktop over TigerVNC:
#
#   source configs/isaac-sim-5.1.0.env
#   source configs/simplepod-tigervnc.env
#   ./isaac_vmctl.sh bootstrap
#
# The bootstrap command installs TigerVNC plus a VNC-friendly GNOME Flashback
# session, writes ~/.vnc/xstartup, and starts display :1 on TCP 5901.

export TIGERVNC_ENABLE=1
export TIGERVNC_DISPLAY=1
export TIGERVNC_PORT=5901
export TIGERVNC_GEOMETRY=1920x1080
export TIGERVNC_DEPTH=24

# 0 means TigerVNC listens on all interfaces so a laptop can connect through
# the SimplePod public IP and mapped/open TCP port. Set to 1 only when using an
# SSH tunnel.
export TIGERVNC_LOCALHOST=0

# Optional. If unset, bootstrap generates an 8-character password once and
# stores it at ~/.vnc/isaac-projects-vnc-password.txt on the VM.
export TIGERVNC_PASSWORD=
