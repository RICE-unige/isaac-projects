# Isaac Sim 6.0.0-dev2 — pre-built configuration  [PREVIEW / UNSTABLE]
#
# Source this file before running isaac_vmctl.sh:
#   source configs/isaac-sim-6.0.0-dev2.env && ./isaac_vmctl.sh start isaacsim
#
# Supported host:  Ubuntu 22.04 (ROS 2 Humble) / Ubuntu 24.04 (ROS 2 Jazzy)
# Min GPU driver:  580.65.06+ (Linux x86_64)
# Lab GPU profile:
#   - RTX 5060 lab workstation for setup and lighter simulation work
#   - RTX 5090 SimplePod for WebRTC and interactive remote Isaac Sim sessions
#   - RTX 6000 Pro Vast.ai for heavier training and headless simulation jobs
# Min system RAM:  32 GB
#
# WebRTC flag style: --/exts/omni.kit.livestream.app/primaryStream/...
#   The "6.*" tag does not match the "5.*" branch in build_isaac_command,
#   so the script uses the 6.x flag set:
#     --/exts/omni.kit.livestream.app/primaryStream/publicIp=<IP>
#     --/exts/omni.kit.livestream.app/primaryStream/signalPort=<PORT>
#     --/exts/omni.kit.livestream.app/primaryStream/streamPort=<PORT>
#   This matches the official Isaac Sim 6.0 documentation exactly.
#
# NGC authentication: this image is publicly pullable from nvcr.io without
#   a login. Set NGC_API_KEY only if your environment requires it.
#
# This is a development preview build — expect instability and breaking
# changes between releases. Not recommended for coursework or assignments.

export ISAAC_IMAGE=nvcr.io/nvidia/isaac-sim:6.0.0-dev2
export CONTAINER_NAME=isaac-sim
export WEBRTC_SIGNAL_PORT=49100
export WEBRTC_STREAM_PORT=47998
export ROS_INSTALL_VARIANT=ros-base
export START_TIMEOUT_SEC=90
export ISAAC_EXTRA_ARGS=
